# Скопіюйте цей файл у .env і заповніть значення.
# На Railway ці самі змінні треба додати у вкладку Variables сервісу.

# ───── Обов'язкові ─────

# Токен бота з @BotFather
BOT_TOKEN=1234567890:AAE_your_token_here

# Ваш Telegram user ID (через @userinfobot) — головний адмін
ADMIN_ID=772817

# ID каналу (через @username_to_id_bot), починається з -100
CHANNEL_ID=-1003958283733

# Юзернейм бота БЕЗ @ — для deep-link
BOT_USERNAME=vzayemodiya_z_pereviznykom_bot

# Шлях до SQLite-файлу. На Railway — /data/bot.db (Volume).
DB_PATH=bot.db

# ───── Опційні (є дефолти) ─────

# О котрій годині (за Києвом) слати щоденний бекап БД супер-адміну.
BACKUP_HOUR_KYIV=9

# Шлях до файлу логів. На Railway рекомендовано /data/bot.log.
LOG_FILE=bot.log
