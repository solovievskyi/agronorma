# Скопіюйте цей файл у .env і заповніть значення.
# На Railway ці самі змінні треба додати у вкладку Variables сервісу.

# Токен бота з @BotFather
BOT_TOKEN=1234567890:AAE_your_token_here

# Ваш Telegram user ID (через @userinfobot)
ADMIN_ID=772817

# ID каналу (через @username_to_id_bot), починається з -100
CHANNEL_ID=-1003958283733

# Юзернейм бота БЕЗ @ — використовується для формування deep-link
BOT_USERNAME=agr0n0rma_bot

# Шлях до SQLite-файлу (за замовчуванням у робочій директорії).
# На Railway рекомендовано підмонтувати Volume і вказати тут,
# наприклад: /data/bot.db
DB_PATH=bot.db
